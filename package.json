{
  "name": "petlar-backend",
  "version": "1.0.0",
  "description": "Backend API and database support for the PetLar adoption platform.",
  "main": "server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "npm run test:backend && npm run test:e2e",
    "test:backend": "vitest run --config vitest.config.mjs",
    "test:backend:watch": "vitest --config vitest.config.mjs",
    "test:unit": "vitest run --config vitest.config.mjs tests/backend/unit",
    "test:integration": "vitest run --config vitest.config.mjs tests/backend/integration",
    "test:coverage": "vitest run --config vitest.config.mjs --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report coverage/e2e/report",
    "test:all:coverage": "npm run test:coverage && echo 'Coverage report in coverage/backend/'"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^1.6.1",
    "cross-env": "^7.0.3",
    "embedded-postgres": "^18.4.0-beta.17",
    "supertest": "^7.2.2",
    "vitest": "^1.6.1"
  }
}
