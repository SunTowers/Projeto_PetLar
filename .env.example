# Copy this file to .env and update the values before running the server. 
# postgresql://postgres:019283746G@b8520@db.lhjwoxvjgapfistqbtvi.supabase.co:5432/postgres
PORT=3000
JWT_SECRET=replace-with-a-secure-secret
CORS_ORIGIN=http://localhost:3000

# PostgreSQL Configuration
# Prefer using a single DATABASE_URL for Render / remote PostgreSQL.
DATABASE_URL=postgresql://user:password@host:5432/database

# Optional fallback fields if you do not use DATABASE_URL.
PG_HOST=localhost
PG_PORT=5432
PG_USER=petlar_user
PG_PASSWORD=replace-with-secure-password
PG_DATABASE=petlar_db
PG_SSL=false
