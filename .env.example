# Copy this file to .env and update the values before running the server.
# Supabase note:
# - Direct connection (port 5432) is IPv6-first.
# - For IPv4-only environments (common on Render), use the Supabase pooler URL.
# - If your password contains "@", encode it as "%40" in DATABASE_URL.
PORT=3000
JWT_SECRET=replace-with-a-secure-secret
CORS_ORIGIN=http://localhost:3000

# PostgreSQL Configuration
# Prefer using a single DATABASE_URL for Render / remote PostgreSQL.
# Example (pooler): postgresql://postgres:PASSWORD_ENCODED@HOST_POOLER:6543/postgres?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/database

# Optional fallback fields if you do not use DATABASE_URL.
PG_HOST=localhost
PG_PORT=5432
PG_USER=petlar_user
PG_PASSWORD=replace-with-secure-password
PG_DATABASE=petlar_db
PG_SSL=true
PG_FAMILY=4
NODE_OPTIONS=--dns-result-order=ipv4first
