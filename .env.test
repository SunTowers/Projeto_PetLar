# Test environment — NEVER use production credentials here.
# Copy and adjust for your local test PostgreSQL instance.
NODE_ENV=test
PORT=0
JWT_SECRET=test-jwt-secret-do-not-use-in-production

# Separate test database — must NOT point to production!
TEST_DATABASE_URL=postgresql://petlar_user:petlar_password@localhost:5432/petlar_test
DATABASE_URL=postgresql://petlar_user:petlar_password@localhost:5432/petlar_test
PG_SSL=false
PG_FAMILY=4

# Playwright
PLAYWRIGHT_BASE_URL=http://localhost:3001
TEST_SERVER_PORT=3001
